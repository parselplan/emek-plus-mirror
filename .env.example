# Harici auth API (opsiyonel). Tanımlı değilse geliştirme modunda sunucu tarafı OTP kullanılır.
# AUTH_API_BASE_URL=https://api.example.com

# Şifreli HttpOnly oturum çerezi için gizli anahtar (production'da zorunlu)
# SESSION_SECRET=your-long-random-secret-at-least-32-chars

# Lovable / preview ortamında OTP'yi logla ve terminalden okunabilir yap
# EMEK_LOG_OTP=true
# EMEK_DEV_OTP_SECRET=emek-dev-otp-local

# Terminalden Lovable preview OTP izleme:
# $env:OTP_WATCH_URL="https://id-preview--<project-id>.lovable.app"
# $env:EMEK_DEV_OTP_SECRET="emek-dev-otp-local"
# npm run otp:watch -- 5535903359

# Beklenen harici endpoint'ler:
# POST /auth/otp/send   { "phone": "5xxxxxxxxx" }
# POST /auth/otp/verify { "phone": "5xxxxxxxxx", "code": "123456" }
# GET  /auth/me         Authorization: Bearer <token>
# verify yanıtı: { "token": "...", "user": { "id": "...", "phone": "5xxxxxxxxx" }, "expiresAt": 1234567890 }
